.fake-badge {
  font-family:'Share Tech Mono',monospace; font-size:0.65rem;
  background:rgba(255,107,53,0.15); color:var(--accent3);
  border:1px solid var(--accent3); border-radius:4px; padding:2px 8px; display:none;
}
.fake-badge.show { display:inline-block; }
.kpi-grid {
  display:grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
  gap:16px; margin-bottom:24px;
}
.kpi {
  background: var(--surface); border:1px solid var(--border); border-radius:12px;
  padding:20px 18px 16px; position:relative; overflow:hidden;
  transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s; cursor:default;
}
.kpi:hover { transform:translateY(-3px); border-color:rgba(0,200,255,0.35); box-shadow:var(--glow); }
.kpi::before {
  content:''; position:absolute; top:0; left:0; right:0; height:2px;
  background: linear-gradient(90deg,transparent,var(--accent),transparent); opacity:0.4;
}
.kpi.warn::before { background:linear-gradient(90deg,transparent,var(--warn),transparent); opacity:0.8; }
.kpi.crit::before { background:linear-gradient(90deg,transparent,var(--danger),transparent); opacity:1; }
.kpi.warn { border-color:rgba(255,183,0,0.35); box-shadow:var(--glow-warn); }
.kpi.crit { border-color:rgba(255,59,92,0.45); box-shadow:var(--glow-danger); animation:shake 0.4s; }
@keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-4px)} 60%{transform:translateX(4px)} }
.kpi-label { font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--text2); letter-spacing:2px; text-transform:uppercase; margin-bottom:8px; }
.kpi-val { font-family:'Orbitron',monospace; font-size:2.4rem; font-weight:700; line-height:1; color:var(--accent); }
.kpi-val.warn { color:var(--warn); }
.kpi-val.crit { color:var(--danger); }
.kpi-unit { font-size:0.9rem; color:var(--text2); font-family:'Rajdhani',sans-serif; font-weight:400; }
.kpi-sub { font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--text2); margin-top:6px; }
.kpi-bar { height:3px; border-radius:2px; margin-top:10px; background:rgba(0,200,255,0.12); overflow:hidden; }
.kpi-bar-fill { height:100%; border-radius:2px; background:linear-gradient(90deg,var(--accent2),var(--accent)); transition:width 0.6s ease; }
.kpi-bar-fill.warn { background:linear-gradient(90deg,var(--warn),#ffd55a); }
.kpi-bar-fill.crit { background:linear-gradient(90deg,var(--danger),#ff8aa0); }
.temp-dual {
  background:var(--surface); border:1px solid var(--border); border-radius:12px;
  padding:20px 18px; margin-bottom:24px;
  display:grid; grid-template-columns:1fr 1fr; gap:16px;
  position:relative; overflow:hidden;
}
.temp-dual::before {
  content:'THERMAL MONITOR'; position:absolute; top:8px; left:50%; transform:translateX(-50%);
  font-family:'Share Tech Mono',monospace; font-size:0.55rem; letter-spacing:4px;
  color:var(--text2); opacity:0.5; white-space:nowrap;
}
.temp-item { text-align:center; padding-top:12px; }
.temp-item .lbl { font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:var(--text2); letter-spacing:2px; margin-bottom:4px; }
.temp-item .val { font-family:'Orbitron',monospace; font-size:1.8rem; font-weight:700; color:var(--accent3); }
.temp-item .delta { font-size:0.7rem; color:var(--text2); font-family:'Share Tech Mono',monospace; margin-top:4px; }
.temp-divider { width:1px; background:var(--border); }
.temp-item.danger .val { color:var(--danger); animation:flicker 1s infinite; }
@keyframes flicker { 0%,100%{opacity:1} 50%{opacity:0.6} }
.charts-row { display:grid; grid-template-columns:2fr 1fr; gap:16px; margin-bottom:24px; }
@media(max-width:900px){ .charts-row { grid-template-columns:1fr; } }
.chart-box { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:18px; }
.chart-title { font-family:'Share Tech Mono',monospace; font-size:0.65rem; letter-spacing:3px; color:var(--accent); text-transform:uppercase; margin-bottom:14px; }
canvas { width:100% !important; }
.alert-log { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:18px; margin-bottom:24px; }
.alert-log-title { font-family:'Share Tech Mono',monospace; font-size:0.65rem; letter-spacing:3px; color:var(--danger); margin-bottom:12px; }
.alert-entry {
  display:flex; align-items:center; gap:10px;
  padding:8px 10px; border-radius:6px; margin-bottom:6px;
  background:rgba(255,59,92,0.07); border-left:3px solid var(--danger);
  font-family:'Share Tech Mono',monospace; font-size:0.72rem; color:var(--text);
  animation: slideIn 0.3s ease;
}
@keyframes slideIn { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:none} }
.alert-entry .atime { color:var(--text2); flex-shrink:0; font-size:0.62rem; }
.no-alerts { color:var(--text2); font-family:'Share Tech Mono',monospace; font-size:0.7rem; }
footer { text-align:center; font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--text2); line-height:1.8; margin-top:40px; opacity:0.6; }
#emergencyBanner {
  display:none; position:fixed; top:0; left:0; right:0; z-index:9999;
  padding:16px; text-align:center;
  background: repeating-linear-gradient(45deg,#ff0026,#ff0026 10px,#800013 10px,#800013 20px);
  font-family:'Orbitron',monospace; font-size:1.1rem; font-weight:900; color:#fff;
  letter-spacing:4px; animation:emBlink 0.5s infinite;
}
@keyframes emBlink { 0%,100%{opacity:1} 50%{opacity:0.7} }
@media(max-width:600px){ .kpi-val{font-size:1.8rem} .logo{font-size:1.1rem} }
</style>
</head>
<body>
<div id="emergencyBanner">⚠ EMERGENCY ACTIVATED — CHECK BATTERY SYSTEM IMMEDIATELY ⚠</div>
<div class="wrapper">

<header>
  <div>
    <div class="logo">AI BATTERY MONITOR <span>SMART HEALTH SYSTEM v2.0</span></div>
  </div>
  <div class="hdr-right">
    <span class="fake-badge" id="fakeBadge">DEMO DATA</span>
    <span class="ts" id="clockTs">--:--:--</span>
    <div class="status-dot" id="statusDot"></div>
  </div>
</header>

<div class="kpi-grid" id="kpiGrid">
  <div class="kpi" id="kpi-v">
    <div class="kpi-label">Battery Voltage</div>
    <div class="kpi-val" id="kv">--<span class="kpi-unit"> V</span></div>
    <div class="kpi-sub" id="kv-sub">--</div>
    <div class="kpi-bar"><div class="kpi-bar-fill" id="kv-bar" style="width:0%"></div></div>
  </div>
  <div class="kpi" id="kpi-soc">
    <div class="kpi-label">State of Charge</div>
    <div class="kpi-val" id="ksoc">--<span class="kpi-unit"> %</span></div>
    <div class="kpi-sub" id="ksoc-sub">--</div>
    <div class="kpi-bar"><div class="kpi-bar-fill" id="ksoc-bar" style="width:0%"></div></div>
  </div>
  <div class="kpi" id="kpi-curr">
    <div class="kpi-label">Discharge Current</div>
    <div class="kpi-val" id="kcurr">--<span class="kpi-unit"> A</span></div>
    <div class="kpi-sub" id="kcurr-sub">--</div>
    <div class="kpi-bar"><div class="kpi-bar-fill" id="kcurr-bar" style="width:0%"></div></div>
  </div>
  <div class="kpi" id="kpi-h">
    <div class="kpi-label">AI Health Index</div>
    <div class="kpi-val" id="kh">--<span class="kpi-unit"> %</span></div>
    <div class="kpi-sub" id="kh-sub">Cycle wear factored</div>
    <div class="kpi-bar"><div class="kpi-bar-fill" id="kh-bar" style="width:0%"></div></div>
  </div>
  <div class="kpi" id="kpi-tte">
    <div class="kpi-label">Time to Empty</div>
    <div class="kpi-val" id="ktte">--<span class="kpi-unit"> min</span></div>
    <div class="kpi-sub" id="ktte-sub">At current draw</div>
    <div class="kpi-bar"><div class="kpi-bar-fill" id="ktte-bar" style="width:0%"></div></div>
  </div>
  <div class="kpi" id="kpi-status">
    <div class="kpi-label">System Status</div>
    <div class="kpi-val" id="kstatus" style="font-size:1.1rem;line-height:1.6;color:var(--safe)">✅ NOMINAL</div>
    <div class="kpi-sub" id="kstatus-sub">--</div>
  </div>
</div>

<div class="temp-dual">
  <div class="temp-item" id="troom-wrap">
    <div class="lbl">ROOM TEMPERATURE</div>
    <div class="val" id="troom">--°C</div>
    <div class="delta" id="troom-sub">Ambient (DHT11)</div>
  </div>
  <div class="temp-divider"></div>
  <div class="temp-item" id="tbatt-wrap">
    <div class="lbl">BATTERY TEMPERATURE</div>
    <div class="val" id="tbatt">--°C</div>
    <div class="delta" id="tbatt-delta">Δ vs room: --°C</div>
  </div>
</div>

<div class="charts-row">
  <div class="chart-box">
    <div class="chart-title">◈ Live Waveforms — Voltage · Current · Health</div>
    <canvas id="waveChart" height="160"></canvas>
  </div>
  <div class="chart-box">
    <div class="chart-title">◈ Thermal Profile</div>
    <canvas id="tempChart" height="160"></canvas>
  </div>
</div>

<div class="alert-log">
  <div class="alert-log-title">◉ ALERT LOG (latest 8 events)</div>
  <div id="alertContainer"><div class="no-alerts">No alerts yet — system nominal.</div></div>
</div>

<footer>
  AI Health = f(Voltage Sag, Thermal Stress, Current Stress, Cycle Wear)<br>
  Battery Temp = Room Temp + I²·R_internal (thermal model)<br>
  Alert tiers: WARNING › CRITICAL › EMERGENCY | Emergency button → GPIO 17
</footer>
</div>

<script>
const MAX_PTS = 30;
const makeDS = (label,color,yAxis)=>({
  label, data:[], borderColor:color,
  backgroundColor: color.replace(')',',0.07)').replace('rgb','rgba'),
  tension:0.35, fill:true, pointRadius:2, pointHoverRadius:5, yAxisID:yAxis
});
const waveChart = new Chart(document.getElementById('waveChart').getContext('2d'),{
  type:'line',
  data:{ labels:[], datasets:[
    makeDS('Voltage (V)','rgb(0,200,255)','y'),
    makeDS('Current (A)','rgb(255,107,53)','y1'),
    makeDS('Health (%)','rgb(0,255,157)','y'),
  ]},
  options:{
    responsive:true, animation:{duration:300},
    interaction:{mode:'index',intersect:false},
    plugins:{ legend:{position:'top',labels:{color:'#8fb8d8',font:{size:11,family:'Share Tech Mono'},usePointStyle:true,pointStyleWidth:8}} },
    scales:{
      y:{min:0,max:5,title:{display:true,text:'V / %×0.05',color:'#6a8aad'},grid:{color:'rgba(0,200,255,0.06)'},ticks:{color:'#6a8aad'}},
      y1:{min:0,max:3,position:'right',title:{display:true,text:'A',color:'rgb(255,107,53)'},grid:{drawOnChartArea:false},ticks:{color:'rgb(255,107,53)'}},
      x:{ticks:{color:'#6a8aad',maxRotation:40,font:{size:9}}}
    }
  }
});
const tempChart = new Chart(document.getElementById('tempChart').getContext('2d'),{
  type:'line',
  data:{ labels:[], datasets:[
    {label:'Room °C',data:[],borderColor:'rgb(100,180,255)',backgroundColor:'rgba(100,180,255,0.07)',tension:0.35,fill:true,pointRadius:2,yAxisID:'yt'},
    {label:'Battery °C',data:[],borderColor:'rgb(255,183,0)',backgroundColor:'rgba(255,183,0,0.07)',tension:0.35,fill:true,pointRadius:2,yAxisID:'yt'},
  ]},
  options:{
    responsive:true, animation:{duration:300},
    interaction:{mode:'index',intersect:false},
    plugins:{ legend:{position:'top',labels:{color:'#8fb8d8',font:{size:11,family:'Share Tech Mono'},usePointStyle:true,pointStyleWidth:8}} },
    scales:{
      yt:{title:{display:true,text:'°C',color:'#6a8aad'},grid:{color:'rgba(0,200,255,0.06)'},ticks:{color:'#6a8aad'}},
      x:{ticks:{color:'#6a8aad',maxRotation:40,font:{size:9}}}
    }
  }
});

function pushChart(ch,ts,vals){
  ch.data.labels.push(ts);
  vals.forEach((v,i)=>ch.data.datasets[i].data.push(v));
  if(ch.data.labels.length>MAX_PTS){ ch.data.labels.shift(); ch.data.datasets.forEach(d=>d.data.shift()); }
  ch.update('none');
}

function setKpi(id,val,cls,barPct,sub){
  const el=document.getElementById(id);
  el.className='kpi-val'+(cls?' '+cls:'');
  el.textContent=val;
  if(barPct!==null){ const bar=document.getElementById(id+'-bar'); if(bar){ bar.style.width=barPct+'%'; bar.className='kpi-bar-fill'+(cls?' '+cls:''); } }
  if(sub!==undefined){ const s=document.getElementById(id+'-sub'); if(s) s.textContent=sub; }
}

async function fetchData(){
  try{
    const r=await fetch('/data'); const d=await r.json();
    const ts=new Date().toLocaleTimeString();
    document.getElementById('clockTs').textContent=ts;
    document.getElementById('fakeBadge').className='fake-badge'+(d.fakeData?' show':'');

    const vPct=((d.v-3.3)/(4.2-3.3)*100).toFixed(0);
    const vCls=d.v<3.5?'crit':d.v<3.7?'warn':'';
    setKpi('kv',d.v.toFixed(2)+' V',vCls,vPct,d.v<3.5?'⚠ Critical voltage':'Nominal');

    const sCls=d.lowCrit?'crit':d.low?'warn':'';
    setKpi('ksoc',d.p.toFixed(0)+' %',sCls,d.p.toFixed(0),d.p<15?'⚠ CRITICAL LOW':d.p<30?'Low — charge soon':'Normal');

    const cPct=Math.min(d.c/2.5*100,100).toFixed(0);
    const cCls=d.ocCrit?'crit':d.oc?'warn':'';
    setKpi('kcurr',d.c.toFixed(2)+' A',cCls,cPct,d.ocCrit?'⚠ Overcurrent!':d.oc?'High draw':'Normal draw');

    const hCls=d.h<50?'crit':d.h<70?'warn':'';
    setKpi('kh',d.h.toFixed(0)+' %',hCls,d.h.toFixed(0),d.h>=85?'Excellent':d.h>=70?'Good':d.h>=50?'Fair':'Poor — check battery');

    const tte=d.tte>9000?'∞':d.tte.toFixed(0);
    const ttePct=d.tte>9000?100:Math.min(d.tte/120*100,100).toFixed(0);
    const tteCls=d.tte<15?'crit':d.tte<30?'warn':'';
    setKpi('ktte',tte+' min',tteCls,ttePct,d.tte>9000?'No load detected':'≈'+(d.tte/60).toFixed(1)+' hrs remaining');

    const statusEl=document.getElementById('kstatus');
    const statusCard=document.getElementById('kpi-status');
    const statusSub=document.getElementById('kstatus-sub');
    const dot=document.getElementById('statusDot');
    const banner=document.getElementById('emergencyBanner');
    if(d.emergency){
      statusEl.innerHTML='🔴 EMERGENCY'; statusEl.style.color='var(--danger)';
      statusCard.className='kpi crit'; dot.className='status-dot alert';
      banner.style.display='block'; statusSub.textContent='Button pressed';
    } else if(d.lowCrit||d.otCrit||d.ocCrit){
      const msgs=[];
      if(d.lowCrit) msgs.push('⚡ Critically Low');
      if(d.otCrit)  msgs.push('🔥 Overheating');
      if(d.ocCrit)  msgs.push('⚠ Overcurrent');
      statusEl.innerHTML=msgs.join('<br>'); statusEl.style.color='var(--danger)';
      statusCard.className='kpi crit'; dot.className='status-dot alert'; banner.style.display='none';
      statusSub.textContent='CRITICAL alerts active';
    } else if(d.low||d.ot||d.oc||d.cold){
      const msgs=[];
      if(d.low)  msgs.push('🔋 Low battery');
      if(d.ot)   msgs.push('🌡 Temp rising');
      if(d.oc)   msgs.push('⚡ High current');
      if(d.cold) msgs.push('❄ Battery cold');
      statusEl.innerHTML=msgs.join('<br>'); statusEl.style.color='var(--warn)';
      statusCard.className='kpi warn'; dot.className='status-dot warn'; banner.style.display='none';
      statusSub.textContent='Warning(s) active';
    } else {
      statusEl.innerHTML='✅ NOMINAL'; statusEl.style.color='var(--safe)';
      statusCard.className='kpi'; dot.className='status-dot'; banner.style.display='none';
      statusSub.textContent='All systems normal';
    }

    document.getElementById('troom').textContent=d.rt.toFixed(1)+'°C';
    document.getElementById('tbatt').textContent=d.bt.toFixed(1)+'°C';
    const delta=(d.bt-d.rt).toFixed(1);
    document.getElementById('tbatt-delta').textContent='Δ vs room: +'+delta+'°C  (I²·R model)';
    document.getElementById('troom-sub').textContent='Ambient — DHT11 live';
    const bWrap=document.getElementById('tbatt-wrap');
    if(d.otCrit){ bWrap.className='temp-item danger'; }
    else if(d.ot){ bWrap.className='temp-item'; document.getElementById('tbatt').style.color='var(--warn)'; }
    else { bWrap.className='temp-item'; document.getElementById('tbatt').style.color='var(--accent3)'; }

    document.getElementById('kpi-v').className='kpi'+(vCls?' '+vCls:'');
    document.getElementById('kpi-soc').className='kpi'+(sCls?' '+sCls:'');
    document.getElementById('kpi-curr').className='kpi'+(cCls?' '+cCls:'');
    document.getElementById('kpi-h').className='kpi'+(hCls?' '+hCls:'');
    document.getElementById('kpi-tte').className='kpi'+(tteCls?' '+tteCls:'');

    pushChart(waveChart,ts,[d.v,d.c,d.h*0.05]);
    pushChart(tempChart,ts,[d.rt,d.bt]);
  } catch(e){ console.error('Fetch error',e); }
}

async function fetchAlerts(){
  try{
    const r=await fetch('/history'); const logs=await r.json();
    const c=document.getElementById('alertContainer');
    if(!logs.length){ c.innerHTML='<div class="no-alerts">No alerts yet — system nominal.</div>'; return; }
    c.innerHTML=logs.map(a=>{
      const sec=Math.floor((Date.now()-a.ts)/1000);
      const timeStr=sec<60?sec+'s ago':(Math.floor(sec/60))+'m ago';
      return '<div class="alert-entry"><span class="atime">['+timeStr+']</span><span>'+a.msg+'</span></div>';
    }).join('');
  } catch(e){}
}

setInterval(()=>{ document.getElementById('clockTs').textContent=new Date().toLocaleTimeString(); },1000);
setInterval(fetchData, 2000);
setInterval(fetchAlerts, 4000);
fetchData(); fetchAlerts();
</script>
</body>
</html>
)rawliteral";
  server.send(200, "text/html", html);
}
