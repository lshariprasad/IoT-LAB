// ─── Buzzer helper ───────────────────────────────────────
void buzzPattern(int times, int onMs, int offMs) {
  for (int i = 0; i < times; i++) {
    digitalWrite(BUZZER_PIN, HIGH); delay(onMs);
    digitalWrite(BUZZER_PIN, LOW);  if (i < times-1) delay(offMs);
  }
}

// ─── Sensors ─────────────────────────────────────────────
void readSensors() {
  if (useFakeData) {
    fakeVoltage  += ((float)random(-3,4)) * 0.005f;
    fakeVoltage   = constrain(fakeVoltage, 3.3f, 4.2f);
    fakeCurrent  += ((float)random(-3,4)) * 0.01f;
    fakeCurrent   = constrain(fakeCurrent, 0.0f, 2.5f);
    fakeRoom     += ((float)random(-2,3)) * 0.1f;
    fakeRoom      = constrain(fakeRoom, 22.0f, 35.0f);
    batteryVoltage = fakeVoltage;
    batteryCurrent = fakeCurrent;
    roomTemp       = fakeRoom;
    batteryTemp    = roomTemp + (batteryCurrent * batteryCurrent * 3.0f);
    return;
  }

  int   raw  = analogRead(VOLT_PIN);
  float adcV = (raw / 4095.0f) * 3.3f;
  float volt = adcV * VOLT_DIVIDER;
  if (volt < 0.5f) { useFakeData = true; return; }

  voltSum -= voltReadings[readIndex];
  voltReadings[readIndex] = volt;
  voltSum += volt;

  float cV  = analogReadMilliVolts(CURR_PIN) / 1000.0f;
  float curr = (cV - currentZeroVoltage) / CURR_SENSITIVITY;
  if (curr < 0) curr = 0;
  currSum -= currReadings[readIndex];
  currReadings[readIndex] = curr;
  currSum += curr;

  readIndex = (readIndex + 1) % NUM_READINGS;
  batteryVoltage = voltSum / NUM_READINGS;
  batteryCurrent = currSum / NUM_READINGS;

  // --- FAKE ROOM TEMPERATURE (DHT11 replaced with synthetic data) ---
  static unsigned long lastTempUpdate = 0;
  static float fakeRoomTemp = 26.0f;
  static float targetRoom = 26.0f;
  if (millis() - lastTempUpdate > 5000) {
    lastTempUpdate = millis();
    targetRoom = random(220, 330) / 10.0f; // 22.0 to 33.0 degrees C
  }
  fakeRoomTemp += (targetRoom - fakeRoomTemp) * 0.1f;
  roomTemp = constrain(fakeRoomTemp, 22.0f, 33.0f);
  // --- END FAKE TEMPERATURE ---

  // Battery temp = room + I²R thermal model
  batteryTemp = roomTemp + (batteryCurrent * batteryCurrent * 3.0f);
}

// ─── Stats & AI health ───────────────────────────────────
void computeStats() {
  batteryPercent = ((batteryVoltage - BATT_MIN_VOLT) / (BATT_MAX_VOLT - BATT_MIN_VOLT)) * 100.0f;
  batteryPercent = constrain(batteryPercent, 0.0f, 100.0f);

  if (batteryCurrent > 0.05f) {
    float remainingMAh = (batteryPercent / 100.0f) * CAPACITY_MAH;
    timeToEmpty = (remainingMAh / (batteryCurrent * 1000.0f)) * 60.0f;
  } else {
    timeToEmpty = 9999.0f;
  }

  float thermalDelta  = batteryTemp - roomTemp;
  float thermalStress = constrain(thermalDelta / TEMP_DELTA_CRIT, 0.0f, 1.0f);
  float currStress    = constrain(batteryCurrent / OVER_CURR_CRIT, 0.0f, 1.0f);
  float voltHealth    = constrain((batteryVoltage - BATT_MIN_VOLT) / (BATT_MAX_VOLT - BATT_MIN_VOLT), 0.0f, 1.0f);
  float cycleWear     = constrain(cycleCount / 5000.0f, 0.0f, 0.20f);

  batteryHealth = (voltHealth * 60.0f)
                + ((1.0f - thermalStress) * 20.0f)
                + ((1.0f - currStress)    * 15.0f)
                - (cycleWear              * 100.0f)
                + 5.0f;
  batteryHealth = constrain(batteryHealth, 0.0f, 100.0f);

  bool prevLowWarn = lowBattWarn;
  lowBattWarn  = (batteryPercent < LOW_BATT_WARN);
  lowBattCrit  = (batteryPercent < LOW_BATT_CRIT);
  overCurrWarn = (batteryCurrent > OVER_CURR_WARN);
  overCurrCrit = (batteryCurrent > OVER_CURR_CRIT);
  overTempWarn = (thermalDelta   > TEMP_DELTA_WARN);
  overTempCrit = (thermalDelta   > TEMP_DELTA_CRIT);
  underTempWarn= (roomTemp       < 10.0f);

  if (!prevLowWarn && lowBattCrit)       pushAlert("CRITICAL: Battery < 15%");
  else if (!prevLowWarn && lowBattWarn)  pushAlert("WARNING: Battery < 30%");
  if (overTempCrit)                      pushAlert("CRITICAL: Battery overheating");
  else if (overTempWarn)                 pushAlert("WARNING: Battery temp rising");
  if (overCurrCrit)                      pushAlert("CRITICAL: Overcurrent detected");
}

// ─── Alerts / buzzer ─────────────────────────────────────
void handleAlerts() {
  if (emergencyActive) return;
  if (overTempCrit || overCurrCrit || lowBattCrit) {
    buzzPattern(3, 200, 100);
  } else if (overTempWarn || overCurrWarn || lowBattWarn) {
    buzzPattern(1, 80, 0);
  } else {
    digitalWrite(BUZZER_PIN, LOW);
  }
}

// ─── Emergency button ────────────────────────────────────
void checkEmergencyButton() {
  static bool lastState = HIGH;
  bool reading = digitalRead(EMERGENCY_PIN);
  if (reading != lastState) lastEmergencyDebounce = millis();
  if ((millis() - lastEmergencyDebounce) > DEBOUNCE_DELAY) {
    if (reading == LOW && !emergencyActive) {
      emergencyActive = true;
      Serial.println("🔴 EMERGENCY TRIGGERED!");
      pushAlert("EMERGENCY button pressed!");
    } else if (reading == HIGH && emergencyActive) {
      emergencyActive = false;
      Serial.println("Emergency cleared.");
      digitalWrite(BUZZER_PIN, LOW);
    }
  }
  lastState = reading;
  if (emergencyActive) digitalWrite(BUZZER_PIN, HIGH);
}

// ─── LED ─────────────────────────────────────────────────
void updateBlueLED() {
  unsigned long now = millis();
  if (emergencyActive) {
    if (now - lastEmergencyBlinkTime >= BLINK_FAST) {
      lastEmergencyBlinkTime = now;
      static bool s = false; s = !s;
      digitalWrite(BLUE_LED_PIN, s);
    }
    return;
  }
  bool anyAlert  = lowBattWarn || overTempWarn || overCurrWarn;
  bool critAlert = lowBattCrit || overTempCrit || overCurrCrit;
  unsigned long interval = critAlert ? BLINK_FAST : (anyAlert ? BLINK_SLOW : 0);
  if (interval == 0) {
    digitalWrite(BLUE_LED_PIN, HIGH);
  } else {
    if (now - lastBlinkTime >= interval) {
      lastBlinkTime = now;
      static bool s = false; s = !s;
      digitalWrite(BLUE_LED_PIN, s);
    }
  }
}

// ─── OLED live display ───────────────────────────────────
void updateDisplay() {
  display.clearDisplay();
  display.setTextSize(1);
  if (emergencyActive) {
    display.fillRect(0, 0, 128, 64, SSD1306_WHITE);
    display.setTextColor(SSD1306_BLACK);
    display.setCursor(12,  2); display.println("!! EMERGENCY !!");
    display.setCursor( 0, 16); display.print("V:"); display.print(batteryVoltage,2);
    display.print("  "); display.print(batteryPercent,0); display.println("%");
    display.setCursor( 0, 30); display.print("I:"); display.print(batteryCurrent,2); display.println("A");
    display.setCursor( 0, 44); display.print("Room:"); display.print(roomTemp,1); display.println("C");
  } else {
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(0,  0); display.println("  BATTERY MONITOR v2");
    display.setCursor(0, 12); display.print("V:"); display.print(batteryVoltage,2);
    display.print("V  SOC:"); display.print(batteryPercent,0); display.println("%");
    display.setCursor(0, 24); display.print("I:"); display.print(batteryCurrent,2); display.println("A");
    display.setCursor(0, 36); display.print("Room:"); display.print(roomTemp,1);
    display.print("C Batt:"); display.print(batteryTemp,1); display.println("C");
    display.setCursor(0, 48); display.print("Health:"); display.print(batteryHealth,0);
    display.print("%  TTE:");
    if (timeToEmpty < 9999) { display.print(timeToEmpty,0); display.println("m"); }
    else display.println("--");
    if (wifiConnected) display.fillCircle(122, 58, 4, SSD1306_WHITE);
  }
  display.display();
}

void printSerial() {
  Serial.println("══════════════════════════════════");
  Serial.printf("Voltage:   %.2f V  |  SOC: %.0f %%\n", batteryVoltage, batteryPercent);
  Serial.printf("Current:   %.2f A\n", batteryCurrent);
  Serial.printf("Room Temp: %.1f °C  |  Batt Temp: %.1f °C\n", roomTemp, batteryTemp);
  Serial.printf("AI Health: %.1f %%  |  TTE: %.0f min\n", batteryHealth, timeToEmpty);
  Serial.printf("Cycles:    %u\n", cycleCount);
  Serial.print("Alerts: ");
  if (emergencyActive) Serial.print("[EMERGENCY] ");
  if (lowBattCrit)     Serial.print("[CRIT:LOW_BATT] ");
  else if (lowBattWarn) Serial.print("[WARN:LOW_BATT] ");
  if (overTempCrit)    Serial.print("[CRIT:OVERHEAT] ");
  else if (overTempWarn) Serial.print("[WARN:TEMP] ");
  if (overCurrCrit)    Serial.print("[CRIT:OVERCURR] ");
  else if (overCurrWarn) Serial.print("[WARN:CURR] ");
  if (!emergencyActive && !lowBattWarn && !overTempWarn && !overCurrWarn) Serial.print("None");
  Serial.println("\n══════════════════════════════════\n");
}

void connectWiFi() {
  Serial.print("Connecting to WiFi");
  WiFi.begin(ssid, password);
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500); Serial.print("."); attempts++;
  }
  wifiConnected = (WiFi.status() == WL_CONNECTED);
  if (wifiConnected) {
    Serial.println("\n✅ WiFi connected!"); Serial.print("IP: "); Serial.println(WiFi.localIP());
  } else {
    Serial.println("\n❌ WiFi failed.");
  }
}

// ─── JSON data endpoint ──────────────────────────────────
void handleData() {
  StaticJsonDocument<512> doc;
  doc["v"]        = batteryVoltage;
  doc["p"]        = batteryPercent;
  doc["c"]        = batteryCurrent;
  doc["rt"]       = roomTemp;
  doc["bt"]       = batteryTemp;
  doc["h"]        = batteryHealth;
  doc["tte"]      = timeToEmpty;
  doc["cc"]       = coulombCount;
  doc["cycles"]   = cycleCount;
  doc["low"]      = lowBattWarn;
  doc["lowCrit"]  = lowBattCrit;
  doc["ot"]       = overTempWarn;
  doc["otCrit"]   = overTempCrit;
  doc["oc"]       = overCurrWarn;
  doc["ocCrit"]   = overCurrCrit;
  doc["cold"]     = underTempWarn;
  doc["emergency"]= emergencyActive;
  doc["fakeData"] = useFakeData;
  String json; serializeJson(doc, json);
  server.send(200, "application/json", json);
}

// ─── Alert history endpoint ───────────────────────────────
void handleHistory() {
  String json = "[";
  int count = min(alertLogHead, 8);
  for (int i = 0; i < count; i++) {
    int idx = (alertLogHead - 1 - i + 8) % 8;
    if (i > 0) json += ",";
    json += "{\"msg\":\"" + alertLog[idx].msg + "\",\"ts\":" + String(alertLog[idx].ts) + "}";
  }
  json += "]";
  server.send(200, "application/json", json);
}

