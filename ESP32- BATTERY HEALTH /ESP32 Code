void setup() {
  Serial.begin(115200);
  Serial.println("\n⚡ EV Battery Monitor v2.0 Starting");

  pinMode(BLUE_LED_PIN, OUTPUT);
  digitalWrite(BLUE_LED_PIN, LOW);
  pinMode(EMERGENCY_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  buzzPattern(2, 80, 60);
  digitalWrite(BLUE_LED_PIN, HIGH); delay(300); digitalWrite(BLUE_LED_PIN, LOW);

  prefs.begin("batt", false);
  cycleCount = prefs.getUInt("cycles", 0);

  Wire.begin(21, 22);
  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println("OLED not found!");
  } else {
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    showScreenTitle();
    screenStage = 0;
    delay(8000);
    showScreenCredits();
    screenStage = 1;
    delay(10000);
  }

  dht.begin();
  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);

  delay(500);
  float zeroSum = 0;
  for (int i = 0; i < 50; i++) {
    zeroSum += analogReadMilliVolts(CURR_PIN) / 1000.0f;
    delay(10);
  }
  currentZeroVoltage = zeroSum / 50.0f;
  Serial.printf("ACS712 zero: %.3f V\n", currentZeroVoltage);
  if (currentZeroVoltage < 0.5f || currentZeroVoltage > 4.5f) {
    useFakeData = true;
    Serial.println("Sensors offline – using demo data.");
  }

  connectWiFi();

  if (wifiConnected) {
    showScreenWiFi(); screenStage = 2; delay(20000);
  } else {
    display.clearDisplay();
    display.setCursor(0,20); display.println("WiFi Failed");
    display.setCursor(0,34); display.println("Offline Mode");
    display.display();
    delay(3000);
  }

  screenStage = 3;
  display.clearDisplay();

  server.on("/",        handleRoot);
  server.on("/data",    handleData);
  server.on("/history", handleHistory);
  if (wifiConnected) server.begin();

  lastCoulombTime = millis();
}

// ══════════════════════════════════════════════════════════
void loop() {
  if (screenStage < 3) { delay(100); return; }

  checkEmergencyButton();

  unsigned long now = millis();

  if (now - lastSensorTime >= SENSOR_INTERVAL) {
    lastSensorTime = now;
    readSensors();
    computeStats();
    handleAlerts();
    updateBlueLED();

    float dtH = (now - lastCoulombTime) / 3600000.0f;
    coulombCount += batteryCurrent * 1000.0f * dtH;
    lastCoulombTime = now;
  }

  if (now - lastDisplayTime >= 1000) {
    lastDisplayTime = now;
    updateDisplay();
    printSerial();
  }

  if (wifiConnected) server.handleClient();
}

